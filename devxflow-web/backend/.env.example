# Environment Configuration
NODE_ENV=development
PORT=3000

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/devxflow

# JWT Secret (generate a strong secret for production)
JWT_SECRET=your-jwt-secret-here

# Cloudinary Configuration (get from https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# GCash QR Code (upload QR image to Cloudinary first)
GCASH_QR_PUBLIC_ID=devxflow-gcash-qr
GCASH_NUMBER=09XX XXX XXXX

# Desktop App API Key (generate a secure random string)
DESKTOP_API_KEY=your-desktop-api-key-here
