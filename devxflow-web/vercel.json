{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/server.js" },
    { "source": "/(.*)", "destination": "/frontend/dist/$1" }
  ],
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "header", "key": "x-forwarded-proto", "value": "http" }], "destination": "https://devxflow.com/$1", "permanent": true }
  ]
}
