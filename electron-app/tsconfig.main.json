{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist-main",
    "rootDir": "src",
    "types": ["node"],
    "esModuleInterop": true
  },
  "include": ["src/main", "src/preload"],
  "exclude": ["src/renderer"]
}
