{
  "name": "devxflow-electron-app",
  "private": true,
  "version": "0.1.0",
  "main": "dist-main/main/index.js",
  "scripts": {
    "dev:renderer": "vite --port 5501 --strictPort",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev": "concurrently --kill-others-on-fail \"npm:dev:main\" \"npm:dev:renderer\" \"wait-on tcp:5501 file:dist-main/main/index.js file:dist-main/main/window.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5501 electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:main && npm run build:renderer",
    "start": "electron .",
    "package": "npm run build && electron-builder build --win --dir",
    "dist": "npm run build && electron-builder build --win"
  },
  "build": {
    "appId": "com.devxflow.pro",
    "productName": "DevXFlowPro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-main/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "public/icon.ico"
    }
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "mssql": "^12.2.0",
    "mysql2": "^3.17.0",
    "pg": "^8.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "simple-git": "^3.27.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/mssql": "^9.1.9",
    "@types/node": "^22.13.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "wait-on": "^8.0.2"
  }
}
